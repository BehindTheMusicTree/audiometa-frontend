# Backend API base URL (no trailing slash). Host only; path prefix is separate.
NEXT_PUBLIC_BACKEND_BASE_URL=https://hear-api.themusictree.org
# URL path segment before audio routes (no slashes), e.g. api root mounted at /my-segment/...
NEXT_PUBLIC_HTMT_API_ROOT_SEGMENT=v2

# URL of docs-bundle.json for the /docs section (required).
NEXT_PUBLIC_DOCS_BUNDLE_URL=https://raw.githubusercontent.com/BehindTheMusicTree/audiometa/main/publish/docs-bundle.json

# Public site origin for canonical URLs, Open Graph, sitemap, and robots (no trailing slash).
NEXT_PUBLIC_SITE_URL=https://audiometa.themusictree.org

# AudioMeta Python library repo URL (footer links; no trailing slash).
AUDIOMETA_PYTHON_GITHUB_REPO_URL=https://github.com/BehindTheMusicTree/audiometa

# PostHog (free tier): project token from PostHog → Project settings (same value as the public snippet).
# US cloud ingest host: https://us.i.posthog.com — EU: https://eu.i.posthog.com
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=phc_replace_with_your_project_token
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
