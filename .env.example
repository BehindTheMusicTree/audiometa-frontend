# Backend API base URL (no trailing slash). Used for metadata requests.
NEXT_PUBLIC_API_BASE_URL=http://hear.themusictree.org/

# Developer credit shown in the footer (e.g. "Your Name" or "Your Company").
NEXT_PUBLIC_SITE_DEVELOPER=Your Name
# Developer GitHub profile URL; the name in the footer links to this.
NEXT_PUBLIC_SITE_DEVELOPER_GITHUB_URL=https://github.com/your-username
# Developer LinkedIn profile URL.
NEXT_PUBLIC_SITE_DEVELOPER_LINKEDIN_URL=https://www.linkedin.com/in/your-username
# Developer Mastodon profile URL.
NEXT_PUBLIC_SITE_DEVELOPER_MASTODON_URL=https://mastodon.social/@your-username
# Developer email (mailto link).
NEXT_PUBLIC_SITE_DEVELOPER_EMAIL=you@example.com
